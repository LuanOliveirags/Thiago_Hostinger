# Variáveis de ambiente — Thiago Bazillio Site
# Copie este arquivo para .env.production e preencha os valores reais.
# NUNCA comite .env.production no repositório.

# ─── Sentry — Monitoramento de erros em produção ─────────────────────────────
# Obtenha em: https://sentry.io → Criar projeto → Browser JavaScript → DSN
VITE_SENTRY_DSN=

# ─── Google Analytics 4 — Rastreamento de eventos ────────────────────────────
# Obtenha em: GA4 → Administrador → Fluxos de dados → Measurement ID (G-XXXXXXXX)
VITE_GA_MEASUREMENT_ID=

# ─── Versão da aplicação ──────────────────────────────────────────────────────
# Injetada no Sentry para rastrear erros por release.
# Atualizado automaticamente pelos scripts release:* no package.json.
VITE_APP_VERSION=2.0.0
